# Copier vers .env et renseigner la clé.
# Sans clé, le jeu tourne en mode "mock" : agents scriptés, pas d'audio (texte seul).
MISTRAL_API_KEY=

# Optionnel : surcharge des identifiants de modèles (défauts dans app/config.py).
# IMPOSTRAL_CHAT_MODEL=mistral-large-latest
# IMPOSTRAL_STT_MODEL=voxtral-mini-latest
# IMPOSTRAL_TTS_MODEL=voxtral-mini-tts-latest

# Optionnel : pool de modèles (séparés par des virgules). Si défini, chaque siège IA
# reçoit un modèle du pool, mélangé à chaque partie, pour comparer leurs performances
# sur la page /stats.html. Vide = tous les sièges utilisent IMPOSTRAL_CHAT_MODEL.
# IMPOSTRAL_MODEL_POOL=mistral-large-latest,mistral-medium-latest,mistral-small-latest
# Fichier JSONL des résultats de partie (défaut : data/results.jsonl).
# IMPOSTRAL_STATS_PATH=data/results.jsonl
